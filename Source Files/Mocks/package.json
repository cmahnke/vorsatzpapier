{
  "name": "@projektemacher/lucienne",
  "version": "0.1.1",
  "type": "module",
  "description": "A IIIF pattern genrator",
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "BSD-3-Clause",
  "exports": {
    "types": "./dist/index.d.ts",
    "import": "./dist/lucienne.js"
  },
  "files": [
    "dist",
    "src",
    "images",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "OpenSeadragon",
    "IIIF",
    "wallpaper",
    "pattern generator"
  ],
  "bugs": {
    "url": "https://github.com/cmahnke/lucienne/issues"
  },
  "repository": {
    "url": "git+https://github.com/cmahnke/lucienne.git"
  },
  "homepage": "https://github.com/cmahnke/lucienne#readme",
  "scripts": {
    "dev": "npm run svgo && vite",
    "vite-build": "npm run clean && npm run svgo && npx vite build",
    "lint": "npx eslint . -c eslint.config.mjs --report-unused-disable-directives --max-warnings 0",
    "stylelint": "npx stylelint '**/*.scss'",
    "format": "npx prettier . --check",
    "tsc": "npx tsc",
    "build": "npm run clean && npm run svgo && npx rollup --config",
    "clean": "npx rimraf ./dist ./public ./src/assets/images/* ./src/assets/fonts/*",
    "svgo": "npx svgo -f ./images -o ./src/assets/images",
    "knip": "npx knip",
    "jsdoc": "npx jsdoc -c jsdoc.config.json -r .",
    "site": "npm run clean && npm run svgo && npx vite build && npm run jsdoc"
  },
  "dependencies": {
    "@allmaps/iiif-parser": "^1.0.0-beta.47",
    "@eslint/js": "^10.0.1",
    "fabric": "^7.3.1",
    "i18next": "^26.0.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "openseadragon": "^6.0.2",
    "openseadragon-fabric-overlay": "^2.0.0"
  },
  "devDependencies": {
    "@allmaps/types": "^1.0.0-beta.22",
    "@fontsource-utils/scss": "^0.2.2",
    "@fontsource-variable/league-spartan": "^5.2.8",
    "@fontsource-variable/raleway": "^5.2.8",
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/i18next": "^13.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.1",
    "better-docs": "^2.7.3",
    "browserslist-to-esbuild": "^2.1.1",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "jsdoc": "^4.0.5",
    "knip": "^6.12.1",
    "postcss": "^8.5.14",
    "postcss-scss": "^4.0.9",
    "postcss-url": "^10.1.3",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.3",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-postcss": "^4.0.2",
    "sass": "^1.99.0",
    "stylelint": "^17.11.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "svgo": "^4.0.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-singlefile": "^2.3.3",
    "vite-plugin-static-copy": "^4.1.0",
    "vite-plugin-stylelint": "^6.1.0",
    "vite-plugin-svgo": "^2.0.0"
  }
}
